%%{init: {'theme': 'dark', 'themeVariables': { 'primaryColor': '#1a1a2e', 'primaryTextColor': '#eee', 'lineColor': '#FFD02F'}, 'flowchart': { 'nodeSpacing': 25, 'rankSpacing': 20 }}}%%

flowchart TB
    classDef done fill:#2a2a4e,stroke:#FFD02F,color:#eee
    classDef active fill:#3a2a1e,stroke:#FFD02F,color:#FFD02F
    classDef pending fill:#1e1e30,stroke:#444,color:#666
    classDef error fill:#4e2a2a,stroke:#ff4444,color:#eee
    classDef success fill:#2a4e2a,stroke:#44ff88,color:#eee

    subgraph S1 [" "]
        direction LR
        A["Postgres"]:::done --> B["00 00 00"]:::done --> C["SIGSEGV"]:::done
    end

    subgraph S2 [" "]
        direction LR
        D["Логгер 100мс"]:::done --> E["Ядро: диск"]:::done --> F["Повтор"]:::success --> G["Работает!"]:::success
    end

    S1 --> S2

    linkStyle 0 stroke:#FFD02F,stroke-width:2px
    linkStyle 1 stroke:#ff4444,stroke-width:2px
    linkStyle 2 stroke:#FFD02F,stroke-width:2px
    linkStyle 3 stroke:#44ff88,stroke-width:2px
    linkStyle 4 stroke:#44ff88,stroke-width:2px
    linkStyle 5 stroke:#44ff88,stroke-width:2px

    style S1 fill:transparent,stroke:transparent
    style S2 fill:transparent,stroke:transparent
