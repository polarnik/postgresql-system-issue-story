%%{init: {'theme': 'dark', 'themeVariables': { 'primaryColor': '#000000', 'primaryTextColor': '#eee', 'lineColor': '#ff9e1f'}, 'flowchart': { 'nodeSpacing': 25, 'rankSpacing': 20 }}}%%

flowchart TB
    classDef done fill:#1a1a1a,stroke:#ff9e1f,color:#eee
    classDef active fill:#2a1500,stroke:#ff9e1f,color:#ff9e1f
    classDef pending fill:#111111,stroke:#444,color:#666
    classDef error fill:#3a1010,stroke:#ff4444,color:#eee
    classDef success fill:#103a10,stroke:#44ff88,color:#eee

    subgraph S1 [" "]
        direction LR
        A["Postgres"]:::done --> B["00 00 00"]:::error --> C["SIGSEGV"]:::error
    end

    subgraph S2 [" "]
        direction LR
        D["Логгер 100мс"]:::active --> E["Ядро: диск"]:::pending --> F["Повтор"]:::pending --> G["Работает!"]:::pending
    end

    S1 --> S2

    linkStyle 0 stroke:#ff9e1f,stroke-width:2px
    linkStyle 1 stroke:#ff4444,stroke-width:2px
    linkStyle 2 stroke:#ff4444,stroke-width:2px
    linkStyle 3 stroke:#444,stroke-width:2px
    linkStyle 4 stroke:#444,stroke-width:2px
    linkStyle 5 stroke:#ff4444,stroke-width:2px

    style S1 fill:transparent,stroke:transparent
    style S2 fill:transparent,stroke:transparent
