%%{init: {'theme': 'base', 'themeVariables': { 'darkMode': true, 'background': '#000000', 'primaryColor': '#ff9e1f', 'primaryTextColor': '#fff', 'primaryBorderColor': '#cc7e19', 'secondaryColor': '#111111', 'secondaryTextColor': '#fff', 'tertiaryColor': '#111111', 'lineColor': '#ff9e1f', 'textColor': '#fff', 'mainBkg': '#111111', 'fontFamily': 'Roboto, sans-serif'}, 'flowchart': { 'nodeSpacing': 25, 'rankSpacing': 20 }}}%%

flowchart TB
    classDef done fill:#1a1a1a,stroke:#ff9e1f,color:#eee
    classDef active fill:#2a1500,stroke:#ff9e1f,color:#ff9e1f
    classDef pending fill:#111111,stroke:#444,color:#666
    classDef error fill:#3a1010,stroke:#ff4444,color:#eee

    subgraph S1 [" "]
        direction LR
        D["Диск"]:::done --> M["Память"]:::error --> CPU["CPU"]:::error
    end

    subgraph S2 [" "]
        direction LR
        R["reclaim"]:::done --> I["init_on_free"]:::done --> BUG["race"]:::active
    end

    S2 --> M

    linkStyle 0 stroke:#ff9e1f,stroke-width:2px
    linkStyle 1 stroke:#ff4444,stroke-width:2px
    linkStyle 2 stroke:#ff9e1f,stroke-width:2px
    linkStyle 3 stroke:#ff9e1f,stroke-width:2px
    linkStyle 4 stroke:#ff4444,stroke-width:2px

    style S1 fill:transparent,stroke:transparent
    style S2 fill:transparent,stroke:transparent
