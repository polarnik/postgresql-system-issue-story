--- a/mm/swap.c
+++ b/mm/swap.c
</span><span class=3D"hunk">@@ -1012,6 +1012,8 @@ void folios_put_refs(stru=
ct folio_batch *folios, unsigned int *refs)
</span> 			free_huge_folio(folio);
